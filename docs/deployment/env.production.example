# ============================================
# KONFIGURASI PRODUCTION ENVIRONMENT
# ============================================
# Copy file ini ke server/.env dan update dengan nilai Anda

# ============================================
# KONFIGURASI DATABASE
# ============================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=wa_blast_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MINIMAL_20_KARAKTER_123!@#$%
DB_NAME=wa_blast_pro

# ============================================
# KONFIGURASI SERVER
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# AUTENTIKASI & KEAMANAN
# ============================================
# Generate dengan: openssl rand -base64 64
JWT_SECRET=GANTI_DENGAN_64_KARAKTER_RANDOM_DARI_OPENSSL
JWT_REFRESH_SECRET=GANTI_DENGAN_64_KARAKTER_RANDOM_LAGI_BERBEDA
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Generate dengan: openssl rand -base64 48
PASSWORD_PEPPER=GANTI_DENGAN_48_KARAKTER_RANDOM_DARI_OPENSSL

# BCrypt rounds (lebih tinggi = lebih aman tapi lebih lambat)
BCRYPT_ROUNDS=12

# ============================================
# KONFIGURASI CORS
# ============================================
# Tambahkan domain production Anda (dipisah koma)
ALLOWED_ORIGINS=https://domain-anda.com,https://www.domain-anda.com,https://api.domain-anda.com

# ============================================
# RATE LIMITING (Production - Ketat)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# ============================================
# SECURITY HEADERS
# ============================================
HELMET_ENABLED=true
ENABLE_HTTPS=true

# ============================================
# KONFIGURASI WHATSAPP
# ============================================
WA_SESSION_PATH=./wa-session
WA_MAX_SESSIONS=10

# ============================================
# KONFIGURASI REDIS
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_PASSWORD_REDIS_MINIMAL_16_KARAKTER

# ============================================
# OPSIONAL: MONITORING & ANALYTICS
# ============================================
# Sentry DSN (untuk error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Google Analytics
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============================================
# OPSIONAL: KONFIGURASI EMAIL
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=email-anda@gmail.com
# SMTP_PASSWORD=app-password-anda
# SMTP_FROM=noreply@domain-anda.com

# ============================================
# OPSIONAL: AWS S3 (untuk upload files)
# ============================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=wa-blast-uploads

# ============================================
# OPSIONAL: CLOUDFLARE
# ============================================
# CLOUDFLARE_API_TOKEN=your-token
# CLOUDFLARE_ZONE_ID=your-zone-id

# ============================================
# KONFIGURASI BACKUP
# ============================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=7
# BACKUP_PATH=/backups

# ============================================
# CATATAN PENTING
# ============================================
# 1. JANGAN commit file ini ke git!
# 2. Gunakan password yang kuat dan random
# 3. Generate secrets dengan: openssl rand -base64 64
# 4. Simpan backup file ini secara aman
# 5. Rotasi secrets secara berkala (setiap 90 hari)
# 6. Gunakan password berbeda untuk setiap environment
# 7. Pertimbangkan menggunakan secret management service
#    (AWS Secrets Manager, HashiCorp Vault, dll)

# ============================================
# CARA GENERATE SECRETS
# ============================================
# 
# JWT_SECRET:
# openssl rand -base64 64 | tr -d '\n' && echo
#
# JWT_REFRESH_SECRET:
# openssl rand -base64 64 | tr -d '\n' && echo
#
# PASSWORD_PEPPER:
# openssl rand -base64 48 | tr -d '\n' && echo
#
# Random Password (20 char):
# openssl rand -base64 20 | tr -d '\n' && echo
