# Test Environment Configuration

NODE_ENV=test

# Database (use separate test database)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wa_blast_pro_test

# Server
PORT=3002

# Auth (test secrets)
JWT_SECRET=test-jwt-secret-key-for-testing-only-do-not-use-in-production
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PASSWORD_PEPPER=test-pepper-key

# Logging
LOG_LEVEL=error
LOG_FILE_PATH=logs/test/

# Disable external services in tests
ENABLE_PERFORMANCE_MONITORING=false
