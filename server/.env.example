# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wa_blast_pro

# Server Configuration
PORT=3001
NODE_ENV=development

# Auth Configuration (MUST be changed in production!)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_64_BYTE_STRING_IN_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_64_BYTE_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password Security
# Generate with: openssl rand -base64 32
PASSWORD_PEPPER=CHANGE_THIS_TO_SECURE_RANDOM_32_BYTE_STRING

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Redis Configuration (optional, for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# Monitoring (optional)
SENTRY_DSN=
ENABLE_PERFORMANCE_MONITORING=false

# WhatsApp Session
WA_SESSION_PATH=./wa-session
WA_MAX_SESSIONS=10

# Security
BCRYPT_ROUNDS=12
ENABLE_HTTPS=false
HELMET_ENABLED=true
