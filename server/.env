# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wa_blast_pro

# Server Configuration
PORT=3001
NODE_ENV=development

# Auth Configuration (Development keys - CHANGE in production!)
JWT_SECRET=dev-jwt-secret-key-12345678901234567890123456789012345678901234567890123456
JWT_REFRESH_SECRET=dev-refresh-secret-key-12345678901234567890123456789012345678901234567890
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PASSWORD_PEPPER=dev-pepper-key-1234567890123456789012345678901234567890

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Rate Limiting (Development - High limits for testing)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# Security
BCRYPT_ROUNDS=12
HELMET_ENABLED=true
ENABLE_HTTPS=false

# WhatsApp Session
WA_SESSION_PATH=./wa-session
WA_MAX_SESSIONS=10
