# Production Environment Configuration
# Copy to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=wa_blast_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!@#
DB_NAME=wa_blast_pro

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_FROM_OPENSSL_COMMAND
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Generate with: openssl rand -base64 48
PASSWORD_PEPPER=REPLACE_WITH_48_CHAR_RANDOM_STRING

# BCrypt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ============================================
# CORS CONFIGURATION
# ============================================
# Add your production domains (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# ============================================
# RATE LIMITING (Production - Strict)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# ============================================
# SECURITY HEADERS
# ============================================
HELMET_ENABLED=true
ENABLE_HTTPS=true

# ============================================
# WHATSAPP CONFIGURATION
# ============================================
WA_SESSION_PATH=./wa-session
WA_MAX_SESSIONS=10

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_REDIS_PASSWORD_HERE

# ============================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================
# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Google Analytics
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ============================================
# OPTIONAL: AWS S3 (for file uploads)
# ============================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=wa-blast-uploads

# ============================================
# OPTIONAL: CLOUDFLARE
# ============================================
# CLOUDFLARE_API_TOKEN=your-token
# CLOUDFLARE_ZONE_ID=your-zone-id

# ============================================
# BACKUP CONFIGURATION
# ============================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=7
# BACKUP_PATH=/backups

# ============================================
# NOTES
# ============================================
# 1. Never commit this file to git!
# 2. Use strong, random passwords
# 3. Generate secrets with: openssl rand -base64 64
# 4. Keep a backup of this file securely
# 5. Rotate secrets periodically (every 90 days)
# 6. Use different passwords for each environment
# 7. Consider using a secret management service (AWS Secrets Manager, HashiCorp Vault)
